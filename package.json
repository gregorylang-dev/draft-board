    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/express": "^5.0.6",
